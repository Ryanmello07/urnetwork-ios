    "When unlinking your referral network, you will no longer be able to earn points from %@." : {
      "comment" : "Used in Main/Account/Settings/UpdateReferralNetworkSheet/UpdateReferralNetworkSheet.swift.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند إلغاء ربط شبكة الإحالة الخاصة بك، لن تتمكن بعد الآن من كسب النقاط من %@."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Když odpojíte svou referální síť, nebudete moci získavat body z %@."
