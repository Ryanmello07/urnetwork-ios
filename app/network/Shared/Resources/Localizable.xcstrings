          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一緒にURnetworkを使いましょう！アプリをインストールして、登録時に私の紹介コードを入力してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
