    "Suggestions for the connected country are marked with its color. Turning one on adds it to the remote DNS servers." : {
      "comment" : "A description of the suggested DNS servers.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الاقتراحات الخاصة بالدولة المتصل بها مميّزة بلونها. تشغيل أحدها يضيفه إلى خوادم DNS البعيدة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Návrhy pro připojenou zemi jsou označeny její barvou. Zapnutím se server přidá mezi vzdálené servery DNS."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vorschläge für das verbundene Land sind mit dessen Farbe markiert. Wenn du einen aktivierst, wird er zu den externen DNS-Servern hinzugefügt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι προτάσεις για τη συνδεδεμένη χώρα επισημαίνονται με το χρώμα της. Αν ενεργοποιήσετε μία, προστίθεται στους απομακρυσμένους διακομιστές DNS."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suggestions for the connected country are marked with its color. Turning one on adds it to the remote DNS servers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las sugerencias del país conectado están marcadas con su color. Al activar una, se añade a los servidores DNS remotos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
