    "Exclusions apply to the whole co-associated network cluster, so related traffic is caught together." : {
      "comment" : "transfer stats and split rules",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تنطبق الاستثناءات على مجموعة الشبكة المرتبطة بالكامل، لذا يتم استثناء حركة المرور ذات الصلة معًا."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Výjimky platí pro celý propojený síťový cluster, takže související provoz je zachycen společně."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ausschlüsse gelten für den gesamten zusammengehörigen Netzwerk-Cluster, sodass verwandter Datenverkehr gemeinsam erfasst wird."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι εξαιρέσεις ισχύουν για ολόκληρη τη συσχετισμένη ομάδα δικτύων, ώστε η σχετική κίνηση να καλύπτεται μαζί."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exclusions apply to the whole co-associated network cluster, so related traffic is caught together."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las exclusiones se aplican a todo el clúster de red asociado, así que el tráfico relacionado queda cubierto en conjunto."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las exclusiones se aplican a todo el clúster de red asociado, así que el tráfico relacionado queda cubierto en conjunto."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las exclusiones se aplican a todo el clúster de red asociado, así que el tráfico relacionado queda cubierto en conjunto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les exclusions s'appliquent à tout le groupe de réseaux associés, afin que le trafic lié soit exclu en même temps."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ההחרגות חלות על כל אשכול הרשת המשויך, כך שתעבורה קשורה נתפסת יחד."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपवाद पूरे संबद्ध नेटवर्क क्लस्टर पर लागू होते हैं, इसलिए संबंधित ट्रैफ़िक एक साथ शामिल हो जाता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pengecualian berlaku untuk seluruh klaster jaringan terkait, sehingga lalu lintas yang berhubungan tercakup bersama."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le esclusioni si applicano all'intero gruppo di reti associate, così il traffico correlato viene escluso insieme."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "除外は関連するネットワーククラスタ全体に適用されるため、関連するトラフィックもまとめて対象になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "제외는 연관된 네트워크 클러스터 전체에 적용되므로 관련 트래픽이 함께 처리됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uitsluitingen gelden voor het hele samenhangende netwerkcluster, zodat gerelateerd verkeer samen wordt meegenomen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wykluczenia dotyczą całego powiązanego klastra sieciowego, więc pokrewny ruch jest obejmowany razem."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As exclusões aplicam-se a todo o cluster de rede coassociado, para que o tráfego relacionado seja abrangido em conjunto."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As exclusões se aplicam a todo o cluster de rede coassociado, para que o tráfego relacionado seja capturado em conjunto."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As exclusões aplicam-se a todo o cluster de rede coassociado, para que o tráfego relacionado seja abrangido em conjunto."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Исключения применяются ко всему связанному сетевому кластеру, поэтому сопутствующий трафик исключается вместе."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Undantag gäller hela det sammankopplade nätverksklustret, så relaterad trafik fångas upp tillsammans."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การยกเว้นจะมีผลกับคลัสเตอร์เครือข่ายที่เกี่ยวข้องกันทั้งกลุ่ม ทราฟฟิกที่เกี่ยวข้องจึงถูกยกเว้นไปพร้อมกัน"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Винятки застосовуються до всього пов'язаного мережевого кластера, тому супутній трафік виключається разом."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loại trừ áp dụng cho toàn bộ cụm mạng liên quan, nên lưu lượng liên quan được gộp chung."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "排除会应用到整个关联网络集群，因此相关流量会被一并排除。"
