          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca il traffico qui sotto per instradarlo localmente, bypassando il tunnel."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下のトラフィックをタップすると、トンネルを迂回してローカルにルーティングされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아래 트래픽을 탭하면 터널을 우회하여 로컬로 라우팅됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
