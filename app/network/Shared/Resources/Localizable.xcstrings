    "Tap traffic below to route it locally, bypassing the tunnel." : {
      "comment" : "A description of how to route traffic locally.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر على حركة المرور أدناه لتوجيهها محليًا وتجاوز النفق."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klepnutím na provoz níže jej nasměrujete lokálně, mimo tunel."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe unten auf Datenverkehr, um ihn lokal zu leiten und den Tunnel zu umgehen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πατήστε την κίνηση παρακάτω για να δρομολογηθεί τοπικά, παρακάμπτοντας το τούνελ."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap traffic below to route it locally, bypassing the tunnel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulsa el tráfico de abajo para enrutarlo localmente, evitando el túnel."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca el tráfico de abajo para enrutarlo localmente, evitando el túnel."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca el tráfico de abajo para enrutarlo localmente, evitando el túnel."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur le trafic ci-dessous pour le router localement, en contournant le tunnel."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הקש על התעבורה שלמטה כדי לנתב אותה מקומית ולעקוף את המנהרה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नीचे किसी ट्रैफ़िक पर टैप करें ताकि वह टनल को बायपास कर स्थानीय रूप से रूट हो।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
