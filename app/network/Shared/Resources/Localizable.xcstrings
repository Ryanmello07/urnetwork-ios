        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pembelian Anda perlu disetujui sebelum dapat diselesaikan. UR Pro akan aktif dengan sendirinya setelah disetujui — tidak perlu membeli lagi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
