    "Payouts occur every Sunday at 00:00 UTC, and require meeting a minimum USDC threshold." : {
      "comment" : "Wallet Screen",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحدث الدفعات كل يوم أحد في الساعة 00:00 بتوقيت UTC، ويتطلب ذلك تحقيق حد أدنى من USDC."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
