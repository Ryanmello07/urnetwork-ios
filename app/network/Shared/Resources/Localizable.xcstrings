          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan också tillåta leverantören att använda mobildata, vilket fungerar utmärkt om du har ett obegränsat abonnemang."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "คุณยังสามารถอนุญาตให้ผู้ให้บริการใช้ข้อมูลเครือข่ายมือถือ ซึ่งเหมาะมากหากคุณมีแพ็กเกจแบบไม่จำกัด"
