        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie Ihr Empfehlungsnetzwerk trennen, können Sie keine Punkte mehr von %@ verdienen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Όταν αποσυνδέετε το δίκτυο παραπομπών σας, δεν θα μπορείτε πλέον να κερδίζετε πόντους από %@."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When unlinking your referral network, you will no longer be able to earn points from %@."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al desvincular tu red de referidos, ya no podrás ganar puntos de %@."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al desvincular tu red de referidos, ya no podrás ganar puntos de %@."
