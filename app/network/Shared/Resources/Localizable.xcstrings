    "You share with others, we share with you. Earn a share of revenue when you provide data to others in the network." : {
      "comment" : "Setup wallet",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت تشارك مع الآخرين، ونحن نشارك معك. اكسب حصة من الإيرادات عندما تقدم بيانات للآخرين على الشبكة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sdílíte s ostatními, my sdílíme s vámi. Získejte podíl na výnosech, když poskytujete data ostatním v síti."
