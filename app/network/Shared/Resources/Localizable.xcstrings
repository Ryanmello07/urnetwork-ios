          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी खरीद पूरी होने से पहले उसे मंज़ूरी मिलनी ज़रूरी है। मंज़ूरी मिलते ही UR Pro अपने आप चालू हो जाएगा — दोबारा खरीदने की ज़रूरत नहीं।"
          }
