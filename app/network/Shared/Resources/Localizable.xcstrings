    "Tell us who you really are. Enter the code we sent you to verify your identity." : {
      "comment" : "Sub header text explaining why verification is needed.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أخبرنا من أنت حقاً. أدخل الرمز الذي أرسلناه إليك للتحقق من هويتك."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Řekněte nám, kdo skutečně jste. Zadejte kód, který jsme vám zaslali k ověření vaší totožnosti."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sagen Sie uns, wer Sie wirklich sind. Geben Sie den Code ein, den wir Ihnen zur Identitätsprüfung gesendet haben."
          }
        },
        "el" : {
