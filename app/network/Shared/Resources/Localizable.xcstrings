    "Don't have a code? Data codes can be purchased at ur.io and emailed to you." : {
      "comment" : "Guidance for someone who has no code yet. Deliberately PLAIN TEXT with no link and no button: app store rules forbid steering a user to an external purchase, but nothing stops us saying where codes come from. Without this, the sheet asks for a code and gives no way to obtain one.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ليس لديك رمز؟ يمكن شراء رموز البيانات من ur.io وإرسالها إلى بريدك الإلكتروني."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nemáte kód? Datové kódy si můžete koupit na ur.io a přijdou vám e-mailem."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Noch keinen Code? Datencodes kannst du auf ur.io kaufen und dir per E-Mail schicken lassen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Δεν έχετε κωδικό; Οι κωδικοί δεδομένων αγοράζονται στο ur.io και αποστέλλονται με email."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don't have a code? Data codes can be purchased at ur.io and emailed to you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿No tienes un código? Puedes comprar códigos de datos en ur.io y te llegarán por correo electrónico."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿No tienes un código? Puedes comprar códigos de datos en ur.io y te llegarán por correo electrónico."
