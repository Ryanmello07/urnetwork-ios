          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você desbloqueará velocidades ainda mais rápidas e acesso prioritário a novos recursos, como medidas robustas contra censura e controle de dados."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
