    "Join me on URnetwork! Get the app and enter my referral code when you sign up." : {
      "comment" : "Used in Shared/Views/ReferralShareLink/ReferralShareLink.swift.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انضم إليّ على URnetwork! حمّل التطبيق وأدخل رمز الإحالة الخاص بي عند التسجيل."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přidejte se ke mně na URnetwork! Stáhněte si aplikaci a při registraci zadejte můj doporučující kód."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komm zu mir auf URnetwork! Hol dir die App und gib bei der Anmeldung meinen Empfehlungscode ein."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Έλα μαζί μου στο URnetwork! Κατέβασε την εφαρμογή και βάλε τον κωδικό παραπομπής μου στην εγγραφή σου."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Join me on URnetwork! Get the app and enter my referral code when you sign up."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Únete a URnetwork conmigo! Descarga la app e introduce mi código de referencia al registrarte."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Únete a URnetwork conmigo! Descarga la app e ingresa mi código de referencia al registrarte."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
