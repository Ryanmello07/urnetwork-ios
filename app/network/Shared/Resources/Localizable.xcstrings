        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Também pode permitir que o fornecedor utilize dados da rede móvel, o que funciona muito bem se tiver um plano ilimitado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
